<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Future Academy"
    Language="1033"
    Version="$(var.ProductVersion)"
    Manufacturer="Windify"
    UpgradeCode="A7B3C4D5-E6F7-4890-ABCD-123456789ABC">
    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Platform="x64"
      Description="Future Academy local hardware link server"
      Comments="Future Academy local hardware link server for https://steam.windify.edu.vn/" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Future Academy is already installed."
      AllowSameVersionUpgrades="yes" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="FutureAcademyIcon" SourceFile="$(var.IconSource)" />
    <Property Id="ARPPRODUCTICON" Value="FutureAcademyIcon" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Future Academy" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Future Academy" />
      </Directory>
    </Directory>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="B8C4D5E6-F7A8-4901-BCDE-234567890ABC">
        <Shortcut
          Id="ApplicationStartMenuShortcut"
          Name="Future Academy"
          Description="Start Future Academy local hardware server"
          Target="[INSTALLFOLDER]WindyLink.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="FutureAcademyIcon"
          IconIndex="0" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Windify\FutureAcademy"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="MainFeature" Title="Future Academy" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>
  </Product>
</Wix>
