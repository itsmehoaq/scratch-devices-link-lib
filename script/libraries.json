            "version": "1.17.4",
            "description": "UART, I2C and SPI abstraction"
        },
        {
            "name": "Adafruit GFX Library",
            "version": "1.12.4",
            "description": "Core graphics library for Adafruit displays"
        },
        {
            "name": "Adafruit Unified Sensor",
            "version": "1.1.15",
            "dirName": "Adafruit_Sensor",
            "description": "Unified sensor abstraction layer"
        },
        {
            "name": "Adafruit SSD1306",
            "version": "2.5.16",
            "description": "SSD1306 OLED driver for 128x64 and 128x32 displays"
        },
        {
            "name": "Adafruit TCS34725",
            "version": "1.4.4",
            "description": "TCS34725 color sensor"
        },
        {
            "name": "Adafruit_VL53L0X",
