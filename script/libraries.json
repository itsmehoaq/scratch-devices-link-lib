        },
        {
            "name": "Servo",
            "version": "1.1.8",
            "description": "Standard Servo library"
        }
    ],

    "github": [
        {
            "owner": "openblockcc",
            "repo": "avr-stl",
            "tag": "v1.0.1",
            "dirName": "avr-stl",
            "description": "STL implementation for AVR"
        },
        {
            "owner": "openblockcc",
            "repo": "ServoK210",
            "tag": "v1.0.0",
            "dirName": "ServoK210",
            "description": "Servo library for K210"
