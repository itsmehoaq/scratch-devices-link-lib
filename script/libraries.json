    "local": [
        "Button",
        "DS18B20",
        "ESP_Scan",
        "Led_Control",
        "Motor",
        "PIR",
        "WS2812B"
    ],

    "_localNote": "Libraries listed in 'local' are custom in-house libraries bundled inside tools archives. They are NOT downloaded by this script – they are expected to already exist after running download-tools.js."
}
